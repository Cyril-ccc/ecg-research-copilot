# Host path of your MIMIC datasets (mounted to /data inside containers)
# For your setup, host data root is /data
MIMIC_DATA_HOST_DIR=/data

# ECG waveform root directory inside container
ECG_DATA_DIR=/data/mimic-iv-ecg-diagnostic-electrocardiogram-matched-subset-1.0

# Global ECG manifest for full mode
ECG_MANIFEST_PATH=/storage/ecg_manifest_full.parquet

# Target schema for full MIMIC-IV import
DATA_SCHEMA=mimiciv_full
